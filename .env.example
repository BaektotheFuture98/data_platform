# Copy this file to .env and adjust local secrets before running Docker Compose.

# PostgreSQL catalog database
POSTGRES_USER=iceberg
POSTGRES_PASSWORD=iceberg
POSTGRES_DB=iceberg_catalog

# MinIO root credentials.
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password

# S3 credentials used by Spark and Iceberg REST.
# Keep these aligned with MINIO_ROOT_* above for the local MinIO stack.
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=password
AWS_REGION=us-east-1

# Iceberg warehouse and S3-compatible endpoint.
CATALOG_WAREHOUSE=s3://warehouse/
# S3_ENDPOINT=http://object-store:9000

# Official Apache image versions used by local Docker builds.
SPARK_BASE_IMAGE=apache/spark:4.0.3-scala2.13-java17-python3-ubuntu
ICEBERG_VERSION=1.10.1
SPARK_MAJOR_MINOR=4.0
SCALA_BINARY_VERSION=2.13
ICEBERG_REST_BASE_IMAGE=apache/iceberg-rest-fixture:1.10.1
